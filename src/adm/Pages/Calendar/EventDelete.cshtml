@page "{id:guid}"
@model FamilyHub.Adm.Pages.Calendar.EventDeleteModel
@{
    ViewData["Title"] = "Slet kalenderbegivenhed";
}

<div class="page-header mb-3">
    <h1 class="h3 mb-1">Slet kalenderbegivenhed</h1>
    <p class="text-muted mb-0">Bekraeft at du vil slette denne begivenhed.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model.Item is null)
        {
            <p class="text-muted mb-0">Begivenheden blev ikke fundet.</p>
        }
        else
        {
            <dl class="row mb-4">
                <dt class="col-sm-3">Titel</dt>
                <dd class="col-sm-9">@Model.Item.Title</dd>
                <dt class="col-sm-3">Dato</dt>
                <dd class="col-sm-9">@Model.Item.EventDate.ToString("yyyy-MM-dd")</dd>
                <dt class="col-sm-3">Tid</dt>
                <dd class="col-sm-9">@Model.TimeRange</dd>
            </dl>

            <form method="post">
                <input type="hidden" asp-for="Item.Id" />
                <button class="btn btn-danger" type="submit">Ja, slet</button>
                <a asp-page="/Calendar/Events" class="btn btn-outline-secondary">Annuller</a>
            </form>
        }
    </div>
</div>
