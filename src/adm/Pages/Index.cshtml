@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var d = Model.Dashboard;

    string Count(int? n) => n?.ToString() ?? "–";
    string LastMod(string key)
    {
        var dt = d.GetLastModified(key);
        return dt.HasValue ? dt.Value.ToString("dd-MM-yyyy HH:mm") + " UTC" : "–";
    }
}

<div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-1">FamilyHub Administrationsportal</h1>
        <p class="text-muted mb-0">Centralt overblik over data, synkronisering og adgang til alle administrationsområder.</p>
    </div>
</div>

<div class="d-flex flex-wrap align-items-center gap-3 mb-4 px-3 py-2 rounded border @(d.IsConnected ? "border-success-subtle bg-success-subtle" : "border-danger-subtle bg-danger-subtle")">
    @if (d.IsConnected)
    {
        <span class="badge text-bg-success fs-6 px-3 py-2">
            <span class="me-1">●</span> API forbundet
        </span>
    }
    else
    {
        <span class="badge text-bg-danger fs-6 px-3 py-2">
            <span class="me-1">●</span> API utilgængeligt
        </span>
    }
    @if (d.Manifest is not null)
    {
        <span class="text-muted small">
            <strong>Manifest genereret:</strong> @d.Manifest.GeneratedAtUtc.ToString("dd-MM-yyyy HH:mm:ss") UTC
        </span>
        <span class="text-muted small">
            <strong>Datasæt:</strong> @d.Manifest.Datasets.Count
        </span>
    }
    <span class="text-muted small ms-auto">
        Tjekket: @(d.CheckedAtUtc == default ? "–" : d.CheckedAtUtc.ToString("HH:mm:ss") + " UTC")
    </span>
</div>

@if (!d.IsConnected)
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4">
        <span class="fw-semibold">API-fejl:</span>
        <span>@d.ErrorMessage</span>
    </div>
}

<h2 class="h6 text-uppercase text-muted fw-semibold mb-2 letter-spacing-1">Dataoverblik</h2>
