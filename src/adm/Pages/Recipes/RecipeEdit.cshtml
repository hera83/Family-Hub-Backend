@page "{id:guid}"
@model FamilyHub.Adm.Pages.Recipes.RecipeEditPageModel
@{
    ViewData["Title"] = "Rediger opskrift";
}

<div class="page-header mb-3">
    <h1 class="h3 mb-1">Rediger opskrift</h1>
    <p class="text-muted mb-0">Opdater opskriftens information.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_FormValidationSummary" />
        <form method="post" class="row g-3">
            <input type="hidden" asp-for="Input.Id" />
            <div class="col-12 col-md-6">
                <label asp-for="Input.Title" class="form-label"></label>
                <input asp-for="Input.Title" class="form-control" />
                <span asp-validation-for="Input.Title" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Input.RecipeCategoryId" class="form-label"></label>
                <select asp-for="Input.RecipeCategoryId" asp-items="Model.CategoryOptions" class="form-select">
                    <option value="">Ingen kategori</option>
                </select>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Input.ImageUrl" class="form-label"></label>
                <input asp-for="Input.ImageUrl" class="form-control" />
                <span asp-validation-for="Input.ImageUrl" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-3">
                <label asp-for="Input.PrepTimeMinutes" class="form-label"></label>
                <input asp-for="Input.PrepTimeMinutes" class="form-control" type="number" min="0" />
                <span asp-validation-for="Input.PrepTimeMinutes" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-3">
                <label asp-for="Input.WaitTimeMinutes" class="form-label"></label>
                <input asp-for="Input.WaitTimeMinutes" class="form-control" type="number" min="0" />
                <span asp-validation-for="Input.WaitTimeMinutes" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Input.Instructions" class="form-label"></label>
                <textarea asp-for="Input.Instructions" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Input.Instructions" class="text-danger"></span>
            </div>
            <div class="col-12 d-flex flex-wrap gap-3">
                <div class="form-check">
                    <input asp-for="Input.IsManual" class="form-check-input" />
                    <label asp-for="Input.IsManual" class="form-check-label"></label>
                </div>
                <div class="form-check">
                    <input asp-for="Input.IsFavorite" class="form-check-input" />
                    <label asp-for="Input.IsFavorite" class="form-check-label"></label>
                </div>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Gem aendringer</button>
                <a asp-page="/Recipes/RecipeDetails" asp-route-id="@Model.Input.Id" class="btn btn-outline-secondary">Annuller</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
