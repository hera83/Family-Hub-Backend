@page "{id:guid}"
@model FamilyHub.Adm.Pages.Catalog.ProductEditPageModel
@{
    ViewData["Title"] = "Rediger produkt";
}

<div class="page-header mb-3">
    <h1 class="h3 mb-1">Rediger produkt</h1>
    <p class="text-muted mb-0">Opdater produktdata og naeringsvaerdier.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_FormValidationSummary" />
        <form method="post" class="row g-3">
            <input type="hidden" asp-for="Input.Id" />
            <div class="col-12 col-md-6">
                <label asp-for="Input.Name" class="form-label"></label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Input.ItemCategoryId" class="form-label"></label>
                <select asp-for="Input.ItemCategoryId" asp-items="Model.CategoryOptions" class="form-select">
                    <option value="">Ingen kategori</option>
                </select>
            </div>
            <div class="col-12">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Input.ImageUrl" class="form-label"></label>
                <input asp-for="Input.ImageUrl" class="form-control" />
                <span asp-validation-for="Input.ImageUrl" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-3">
                <label asp-for="Input.Unit" class="form-label"></label>
                <input asp-for="Input.Unit" class="form-control" />
                <span asp-validation-for="Input.Unit" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-3">
                <label asp-for="Input.SizeLabel" class="form-label"></label>
                <input asp-for="Input.SizeLabel" class="form-control" />
                <span asp-validation-for="Input.SizeLabel" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-3">
                <label asp-for="Input.Price" class="form-label"></label>
                <input asp-for="Input.Price" class="form-control" type="number" min="0" step="0.01" />
                <span asp-validation-for="Input.Price" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-9 d-flex flex-wrap gap-3 align-items-end">
                <div class="form-check">
                    <input asp-for="Input.IsManual" class="form-check-input" />
                    <label asp-for="Input.IsManual" class="form-check-label"></label>
                </div>
                <div class="form-check">
                    <input asp-for="Input.IsFavorite" class="form-check-input" />
                    <label asp-for="Input.IsFavorite" class="form-check-label"></label>
                </div>
                <div class="form-check">
                    <input asp-for="Input.IsStaple" class="form-check-input" />
                    <label asp-for="Input.IsStaple" class="form-check-label"></label>
                </div>
            </div>

            <div class="col-12"><hr class="my-1" /></div>
            <div class="col-12"><h2 class="h6 mb-0">Naeringsindhold pr. 100 g</h2></div>

            <div class="col-6 col-md-2">
                <label asp-for="Input.CaloriesPer100g" class="form-label"></label>
                <input asp-for="Input.CaloriesPer100g" class="form-control" type="number" min="0" step="0.01" />
                <span asp-validation-for="Input.CaloriesPer100g" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-2">
                <label asp-for="Input.FatPer100g" class="form-label"></label>
                <input asp-for="Input.FatPer100g" class="form-control" type="number" min="0" step="0.01" />
                <span asp-validation-for="Input.FatPer100g" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-2">
                <label asp-for="Input.CarbsPer100g" class="form-label"></label>
                <input asp-for="Input.CarbsPer100g" class="form-control" type="number" min="0" step="0.01" />
                <span asp-validation-for="Input.CarbsPer100g" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-2">
                <label asp-for="Input.ProteinPer100g" class="form-label"></label>
                <input asp-for="Input.ProteinPer100g" class="form-control" type="number" min="0" step="0.01" />
                <span asp-validation-for="Input.ProteinPer100g" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-2">
                <label asp-for="Input.FiberPer100g" class="form-label"></label>
                <input asp-for="Input.FiberPer100g" class="form-control" type="number" min="0" step="0.01" />
                <span asp-validation-for="Input.FiberPer100g" class="text-danger"></span>
            </div>

            <div class="col-12">
                <button type="submit" class="btn btn-primary">Gem aendringer</button>
                <a asp-page="/Catalog/Products" class="btn btn-outline-secondary">Annuller</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
