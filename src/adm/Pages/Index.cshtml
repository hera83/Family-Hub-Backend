            <div class="col-12 col-sm-6 col-lg-3">
                <a class="btn btn-outline-secondary w-100 text-start" asp-page="/Catalog/Categories">
                    <span class="fw-semibold d-block">Madvarekategorier</span>
                    <span class="small text-muted">Organiser kategorier</span>
                </a>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <a class="btn btn-outline-secondary w-100 text-start" asp-page="/Catalog/Products">
