@page "{id:guid}"
@model FamilyHub.Adm.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = "Ordredetaljer";
}

<div class="page-header mb-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
    <div>
        <h1 class="h3 mb-1">Ordredetaljer</h1>
        <p class="text-muted mb-0">Visning af ordre, ordrelinjer og PDF-status.</p>
    </div>
    @if (Model.Item is not null)
    {
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-page="/Orders/Index">Tilbage til liste</a>
            <a class="btn btn-outline-secondary" asp-page="/Orders/Pdf" asp-route-id="@Model.Item.Id">PDF-info</a>
            <a class="btn btn-outline-danger" asp-page="/Orders/Delete" asp-route-id="@Model.Item.Id">Slet ordre</a>
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
{
    <div class="alert alert-danger" role="alert">@Model.LoadErrorMessage</div>
}
else if (Model.Item is null)
{
    <div class="alert alert-warning" role="alert">Ordren blev ikke fundet.</div>
}
else
{
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h2 class="h5 mb-3">Ordre</h2>
            <dl class="row mb-0">
                <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Item.Status</dd>
                <dt class="col-sm-3">Antal varer</dt><dd class="col-sm-9">@Model.Item.TotalItems</dd>
                <dt class="col-sm-3">Totalpris</dt><dd class="col-sm-9">@Model.FormatPrice(Model.Item.TotalPrice)</dd>
                <dt class="col-sm-3">Har PDF</dt><dd class="col-sm-9">@(Model.Item.HasPdf ? "Ja" : "Nej")</dd>
                <dt class="col-sm-3">Noter</dt><dd class="col-sm-9">@(Model.Item.Notes ?? "-")</dd>
                <dt class="col-sm-3">Oprettet</dt><dd class="col-sm-9">@Model.FormatUtc(Model.Item.CreatedAtUtc)</dd>
                <dt class="col-sm-3">Opdateret</dt><dd class="col-sm-9">@Model.FormatNullableUtc(Model.Item.UpdatedAtUtc)</dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Ordrelinjer</h2>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Produkt</th>
                        <th>Kategori</th>
                        <th>Antal</th>
                        <th>Enhed</th>
                        <th>Pris</th>
                        <th>Størrelse</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.Item.Lines.Count == 0)
                    {
                        <tr><td colspan="6" class="text-muted">Ingen ordrelinjer.</td></tr>
                    }
                    else
                    {
                        foreach (var line in Model.Item.Lines)
                        {
                            <tr>
                                <td>@line.ProductName</td>
                                <td>@(line.CategoryName ?? "-")</td>
                                <td>@Model.FormatQuantity(line.Quantity)</td>
                                <td>@(line.Unit ?? "-")</td>
                                <td>@Model.FormatPrice(line.Price)</td>
                                <td>@(line.SizeLabel ?? "-")</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
