# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and configure with your values
# Reference: docker-compose.yml will interpolate these variables
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your settings
#   docker-compose up -d
#
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Shared Configuration
# ─────────────────────────────────────────────────────────────────────────────

# API Key used by both API and ADM services
# Change this to a secure random string in production
API_KEY=dev-api-key-12345

# ─────────────────────────────────────────────────────────────────────────────
# API Service Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Database path (inside container - mounted via volume)
# This should match the volume mount path in docker-compose.yml
API_DATABASE_PATH=/data/familyhub.db

# Host port for API (external)
# Default: 5000 (mapped to 8080 inside container)
API_HOST_PORT=5000

# Logging level for API
# Options: Trace, Debug, Information, Warning, Error, Critical
API_LOG_LEVEL=Information

# Enable Swagger UI in production
# Options: true, false
API_SWAGGER_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# ADM Service Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Host port for ADM (external)
# Default: 5001 (mapped to 8080 inside container)
ADM_HOST_PORT=5001

# Logging level for ADM
# Options: Trace, Debug, Information, Warning, Error, Critical
ADM_LOG_LEVEL=Information

# ─────────────────────────────────────────────────────────────────────────────
# Notes for Production Deployment
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Change API_KEY to a strong random value:
#    - Use: openssl rand -base64 32
#    - Or: python -c "import secrets; print(secrets.token_hex(32))"
#
# 2. Use a reverse proxy (nginx, traefik) in front:
#    - This provides HTTPS/TLS termination
#    - Load balancing if needed
#    - Security headers
#
# 3. Mount SQLite volume from a reliable location:
#    - Use named volumes (recommended for production)
#    - Or bind-mount to a backup location
#
# 4. Run health checks:
#    - API: http://localhost:5000/health
#    - Monitor logs: docker-compose logs -f api
#
# 5. Database backups:
#    - Regularly backup /data/familyhub.db
#    - Keep on separate storage
#
# 6. Update images:
#    - Rebuild when code changes: docker-compose up -d --build
#    - Or pull pre-built images from a registry
#
