@page "{id:guid}"
@model FamilyHub.Adm.Pages.Orders.DeleteModel
@{
    ViewData["Title"] = "Slet ordre";
}

<div class="page-header mb-3">
    <h1 class="h3 mb-1">Slet ordre</h1>
    <p class="text-muted mb-0">Bekræft at du vil slette denne ordre og alle ordrelinjer.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model.Item is null)
        {
            <p class="text-muted mb-0">Ordren blev ikke fundet.</p>
        }
        else
        {
            <dl class="row mb-4">
                <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Item.Status</dd>
                <dt class="col-sm-3">Antal varer</dt><dd class="col-sm-9">@Model.Item.TotalItems</dd>
                <dt class="col-sm-3">Totalpris</dt><dd class="col-sm-9">@Model.FormatPrice(Model.Item.TotalPrice)</dd>
                <dt class="col-sm-3">Har PDF</dt><dd class="col-sm-9">@(Model.Item.HasPdf ? "Ja" : "Nej")</dd>
            </dl>

            <form method="post">
                <input type="hidden" asp-for="Item.Id" />
                <button class="btn btn-danger" type="submit">Ja, slet</button>
                <a asp-page="/Orders/Index" class="btn btn-outline-secondary">Annuller</a>
            </form>
        }
    </div>
</div>
