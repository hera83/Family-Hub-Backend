@page "{id:guid}"
@model FamilyHub.Adm.Pages.Calendar.FamilyMemberEditPageModel
@{
    ViewData["Title"] = "Rediger familiemedlem";
}

<div class="page-header mb-3">
    <h1 class="h3 mb-1">Rediger familiemedlem</h1>
    <p class="text-muted mb-0">Opdater navn og farve.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_FormValidationSummary" />
        <form method="post" class="row g-3">
            <input type="hidden" asp-for="Input.Id" />
            <div class="col-12 col-md-6">
                <label asp-for="Input.Name" class="form-label"></label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="Input.Color" class="form-label"></label>
                <input asp-for="Input.Color" class="form-control" />
                <span asp-validation-for="Input.Color" class="text-danger"></span>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Gem aendringer</button>
                <a asp-page="/Calendar/FamilyMembers" class="btn btn-outline-secondary">Annuller</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
