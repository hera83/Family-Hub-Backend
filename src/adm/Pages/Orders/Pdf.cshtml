@page "{id:guid}"
@model FamilyHub.Adm.Pages.Orders.PdfModel
@{
    ViewData["Title"] = "Ordre PDF-info";
}

<div class="page-header mb-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
    <div>
        <h1 class="h3 mb-1">Ordre PDF-info</h1>
        <p class="text-muted mb-0">Visning af PDF-metadata og tekstbaseret PdfData fra API.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-page="/Orders/Index">Tilbage til liste</a>
        <a class="btn btn-outline-secondary" asp-page="/Orders/Details" asp-route-id="@RouteData.Values["id"]">Tilbage til ordre</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
{
    <div class="alert alert-danger" role="alert">@Model.LoadErrorMessage</div>
}
else if (Model.Item is null)
{
    <div class="alert alert-warning" role="alert">Ordren blev ikke fundet.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-4">
                <dt class="col-sm-3">OrderId</dt><dd class="col-sm-9">@Model.Item.OrderId</dd>
                <dt class="col-sm-3">Har PDF</dt><dd class="col-sm-9">@(Model.Item.HasPdf ? "Ja" : "Nej")</dd>
                <dt class="col-sm-3">ContentType</dt><dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Item.ContentType) ? "-" : Model.Item.ContentType)</dd>
                <dt class="col-sm-3">FileName</dt><dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Item.FileName) ? "-" : Model.Item.FileName)</dd>
            </dl>

            @if (Model.Item.HasPdf && !string.IsNullOrWhiteSpace(Model.Item.PdfData))
            {
                <div class="mb-3">
                    <form method="post" asp-page-handler="Download" asp-route-id="@Model.Item.OrderId">
                        <button class="btn btn-primary" type="submit">Download PDF-data (.txt)</button>
                    </form>
                </div>

                <div>
                    <label class="form-label fw-semibold">PdfData (preview)</label>
                    <textarea class="form-control" rows="10" readonly>@Model.Item.PdfData</textarea>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Ingen PDF-data gemt for denne ordre.</p>
            }
        </div>
    </div>
}
