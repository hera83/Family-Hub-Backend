</div>

@if (d.Manifest?.Datasets.Count > 0)
{
    <div class="card shadow-sm">
        <div class="card-header">
            <h2 class="h6 mb-0 fw-semibold">Sync Manifest – datasætoversigt</h2>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Datasæt</th>
                        <th scope="col" class="text-end">Antal poster</th>
                        <th scope="col">Sidst ændret (UTC)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ds in d.Manifest.Datasets.OrderBy(x => x.DatasetName))
                    {
                        <tr>
                            <td class="fw-medium">@ds.DatasetName</td>
                            <td class="text-end">@ds.TotalCount</td>
                            <td>
                                @if (ds.LastModifiedUtc.HasValue)
                                {
                                    <span>@ds.LastModifiedUtc.Value.ToString("dd-MM-yyyy HH:mm:ss")</span>
                                }
                                else
                                {
                                    <span class="text-muted">–</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted small">
            Manifest genereret: @d.Manifest.GeneratedAtUtc.ToString("dd-MM-yyyy HH:mm:ss") UTC
        </div>
    </div>
}

