{
  "Database": {
    "Path": "familyhub.db",
    "AutoMigrateOnStartup": true,
    "RecreateIfNoMigrations": true,
    "SeedOnStartup": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=familyhub.db"
  },
  "ApiKey": {
    "Enabled": true,
    "HeaderName": "x-api-key",
    "Key": "dev-api-key-12345"
  },
  "Swagger": {
    "EnableInProduction": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
