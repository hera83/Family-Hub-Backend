@page "{recipeId:guid}/{ingredientId:guid}"
@model FamilyHub.Adm.Pages.Recipes.IngredientDeleteModel
@{
    ViewData["Title"] = "Slet ingrediens";
}

<div class="page-header mb-3">
    <h1 class="h3 mb-1">Slet ingrediens</h1>
    <p class="text-muted mb-0">Bekraeft at du vil slette denne ingrediens.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model.Item is null)
        {
            <p class="text-muted mb-0">Ingrediensen blev ikke fundet.</p>
        }
        else
        {
            <dl class="row mb-4">
                <dt class="col-sm-3">Produkt</dt><dd class="col-sm-9">@(Model.Item.ProductName ?? "-")</dd>
                <dt class="col-sm-3">Navn</dt><dd class="col-sm-9">@(Model.Item.Name ?? "-")</dd>
                <dt class="col-sm-3">Maengde</dt><dd class="col-sm-9">@(Model.Item.Quantity?.ToString("0.##") ?? "-") @(Model.Item.Unit ?? string.Empty)</dd>
            </dl>

            <form method="post">
                <input type="hidden" asp-for="Item.Id" />
                <input type="hidden" asp-for="Item.RecipeId" />
                <button class="btn btn-danger" type="submit">Ja, slet</button>
                <a asp-page="/Recipes/RecipeDetails" asp-route-id="@Model.Item.RecipeId" class="btn btn-outline-secondary">Annuller</a>
            </form>
        }
    </div>
</div>
