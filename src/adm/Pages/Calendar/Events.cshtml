@page
@model FamilyHub.Adm.Pages.Calendar.EventsModel
@{
    ViewData["Title"] = "Kalenderbegivenheder";
}

<div class="page-header mb-3">
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
        <div>
            <h1 class="h3 mb-1">Kalenderbegivenheder</h1>
            <p class="text-muted mb-0">Faa overblik over kommende aktiviteter og rediger detaljer.</p>
        </div>
        <a class="btn btn-primary" asp-page="/Calendar/EventCreate">Opret begivenhed</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h2 class="h5 mb-3">Liste</h2>

        @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.LoadErrorMessage</div>
        }

        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead>
                <tr>
                    <th>Titel</th>
                    <th>Dato</th>
                    <th>Tid</th>
                    <th>Familiemedlem</th>
                    <th>Gentagelse</th>
                    <th class="text-end">Handlinger</th>
                </tr>
                </thead>
                <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-muted">Ingen kalenderbegivenheder fundet.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.EventDate.ToString("yyyy-MM-dd")</td>
                            <td>@Model.FormatTimeRange(item.StartTime, item.EndTime)</td>
                            <td>
                                <span class="d-inline-flex align-items-center gap-2">
                                    @if (!string.IsNullOrWhiteSpace(item.FamilyMemberColor))
                                    {
                                        <span class="rounded-circle border" style="display:inline-block;width:14px;height:14px;background-color:@item.FamilyMemberColor"></span>
                                    }
                                    <span>@(item.FamilyMemberName ?? "-")</span>
                                </span>
                            </td>
                            <td>@Model.FormatRecurrence(item)</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-page="/Calendar/EventEdit" asp-route-id="@item.Id">Rediger</a>
                                <a class="btn btn-sm btn-outline-danger" asp-page="/Calendar/EventDelete" asp-route-id="@item.Id">Slet</a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
