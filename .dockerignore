# ─────────────────────────────────────────────────────────────────────────────
# Docker Build Context Exclusions
# ─────────────────────────────────────────────────────────────────────────────

# Build outputs
**/bin/
**/obj/

# IDE and editor files
.vs/
.vscode/
*.swp
*.swo
*~
.DS_Store
*.user
*.suo
*.codeowners
*.editorconfig

# Git
.git/
.gitignore
.gitattributes

# Package managers
node_modules/
package-lock.json
yarn.lock

# Database files (local dev)
*.db
*.sqlite
*.sqlite3

# Temporary files
*.tmp
*.temp
Thumbs.db

# Docker files (don't duplicate in build)
Dockerfile
docker-compose*.yml
.dockerignore
.env
.env.*

# Documentation
README.md
CONTRIBUTING.md
LICENSE
CHANGELOG.md

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Test files
**/test-results/
**/coverage/

# System files
.DS_Store
.AppleDouble
.LSOverride
*.log
