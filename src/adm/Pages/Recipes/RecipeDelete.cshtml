@page "{id:guid}"
@model FamilyHub.Adm.Pages.Recipes.RecipeDeleteModel
@{
    ViewData["Title"] = "Slet opskrift";
}

<div class="page-header mb-3">
    <h1 class="h3 mb-1">Slet opskrift</h1>
    <p class="text-muted mb-0">Bekraeft at du vil slette denne opskrift.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model.Item is null)
        {
            <p class="text-muted mb-0">Opskriften blev ikke fundet.</p>
        }
        else
        {
            <dl class="row mb-4">
                <dt class="col-sm-3">Titel</dt>
                <dd class="col-sm-9">@Model.Item.Title</dd>
                <dt class="col-sm-3">Kategori</dt>
                <dd class="col-sm-9">@(Model.Item.RecipeCategoryName ?? "-")</dd>
                <dt class="col-sm-3">Forberedelse</dt>
                <dd class="col-sm-9">@(Model.Item.PrepTimeMinutes?.ToString() ?? "-") min</dd>
                <dt class="col-sm-3">Ventetid</dt>
                <dd class="col-sm-9">@(Model.Item.WaitTimeMinutes?.ToString() ?? "-") min</dd>
            </dl>

            <form method="post">
                <input type="hidden" asp-for="Item.Id" />
                <button class="btn btn-danger" type="submit">Ja, slet</button>
                <a asp-page="/Recipes/Index" class="btn btn-outline-secondary">Annuller</a>
            </form>
        }
    </div>
</div>
