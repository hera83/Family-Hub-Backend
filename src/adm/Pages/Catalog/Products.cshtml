@page
@model FamilyHub.Adm.Pages.Catalog.ProductsModel
@{
    ViewData["Title"] = "Madvarer";
}

<div class="page-header mb-3">
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
        <div>
            <h1 class="h3 mb-1">Madvarer</h1>
            <p class="text-muted mb-0">Administrer produkter, priser og kategori-tilknytning.</p>
        </div>
        <a class="btn btn-primary" asp-page="/Catalog/ProductCreate">Opret produkt</a>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <h2 class="h5 mb-3">Soeg</h2>
        <form method="get" class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label" asp-for="Search">Navn eller beskrivelse</label>
                <input asp-for="Search" class="form-control" placeholder="Soeg..." />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" asp-for="CategoryId">Kategori</label>
                <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                    <option value="">Alle kategorier</option>
                </select>
            </div>
            <div class="col-12 col-md-2 d-flex align-items-end">
                <button class="btn btn-outline-primary w-100" type="submit">Soeg</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h2 class="h5 mb-3">Liste</h2>

        @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.LoadErrorMessage</div>
        }

        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead>
                <tr>
                    <th>Navn</th>
                    <th>Kategori</th>
                    <th>Enhed</th>
                    <th>Stoerrelse</th>
                    <th>Pris</th>
                    <th>Favorit</th>
                    <th>Basisvare</th>
                    <th class="text-end">Handlinger</th>
                </tr>
                </thead>
                <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-muted">Ingen produkter fundet.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@(item.ItemCategoryName ?? "-")</td>
                            <td>@(item.Unit ?? "-")</td>
                            <td>@(item.SizeLabel ?? "-")</td>
                            <td>@Model.FormatPrice(item.Price)</td>
                            <td>@(item.IsFavorite ? "Ja" : "Nej")</td>
                            <td>@(item.IsStaple ? "Ja" : "Nej")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-page="/Catalog/ProductDetails" asp-route-id="@item.Id">Detaljer</a>
                                <a class="btn btn-sm btn-outline-secondary" asp-page="/Catalog/ProductEdit" asp-route-id="@item.Id">Rediger</a>
                                <a class="btn btn-sm btn-outline-danger" asp-page="/Catalog/ProductDelete" asp-route-id="@item.Id">Slet</a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
