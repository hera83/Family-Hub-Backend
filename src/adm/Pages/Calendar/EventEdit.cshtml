@page "{id:guid}"
@model FamilyHub.Adm.Pages.Calendar.EventEditPageModel
@{
    ViewData["Title"] = "Rediger kalenderbegivenhed";
}

<div class="page-header mb-3">
    <h1 class="h3 mb-1">Rediger kalenderbegivenhed</h1>
    <p class="text-muted mb-0">Opdater detaljer for den valgte begivenhed.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <partial name="_FormValidationSummary" />
        <form method="post" class="row g-3">
            <input type="hidden" asp-for="Input.Id" />
            <div class="col-12 col-md-6">
                <label asp-for="Input.Title" class="form-label"></label>
                <input asp-for="Input.Title" class="form-control" />
                <span asp-validation-for="Input.Title" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6">
                <label asp-for="Input.FamilyMemberId" class="form-label"></label>
                <select asp-for="Input.FamilyMemberId" asp-items="Model.FamilyMemberOptions" class="form-select">
                    <option value="">Ingen</option>
                </select>
            </div>
            <div class="col-12">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="Input.EventDate" class="form-label"></label>
                <input asp-for="Input.EventDate" type="date" class="form-control" />
                <span asp-validation-for="Input.EventDate" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-4">
                <label asp-for="Input.StartTime" class="form-label"></label>
                <input asp-for="Input.StartTime" type="time" class="form-control" />
                <span asp-validation-for="Input.StartTime" class="text-danger"></span>
            </div>
            <div class="col-6 col-md-4">
                <label asp-for="Input.EndTime" class="form-label"></label>
                <input asp-for="Input.EndTime" type="time" class="form-control" />
                <span asp-validation-for="Input.EndTime" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-4">
                <label asp-for="Input.RecurrenceType" class="form-label"></label>
                <select asp-for="Input.RecurrenceType" asp-items="Model.RecurrenceTypeOptions" class="form-select">
                    <option value="">Ingen</option>
                </select>
                <span asp-validation-for="Input.RecurrenceType" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label class="form-label">Gentagelsesdage</label>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var day in Model.RecurrenceDayOptions)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="Input.RecurrenceDays" value="@day.Value" id="rd-@day.Value" checked="@Model.Input.RecurrenceDays.Contains(day.Value)" />
                            <label class="form-check-label" for="rd-@day.Value">@day.Label</label>
                        </div>
                    }
                </div>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Gem aendringer</button>
                <a asp-page="/Calendar/Events" class="btn btn-outline-secondary">Annuller</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
